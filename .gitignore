# belong in the game install, never the repo.
mod/**/chaos_state.json
mod/**/chaos_status.json
mod/**/bridge_path.txt
*.tmp

# ── logs / misc ───────────────────────────────────────────────────
*.log
.luacheckcache
luacov.stats.out
luacov.report.out
