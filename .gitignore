/vote-engine/vote-engine
/vote-engine/vote-engine.exe
/vote-engine/dist/
*.test

# Streamer's real config (may contain tokens) — only the example is tracked
config.yaml
config.yml

# ── runtime bridge files (written at play time) ───────────────────
